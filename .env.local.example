# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://leads.depgrow.in

# ── Razorpay ──────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ── WhatsApp — WATI (preferred) ───────────────────────────────────────────
# Get from app.wati.io → API → Access Token
WATI_API_KEY=your-wati-bearer-token
WATI_API_ENDPOINT=https://live-mt-server.wati.io/YOUR_ACCOUNT_ID

# ── WhatsApp — Twilio (fallback) ──────────────────────────────────────────
# Get from twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WA_FROM=whatsapp:+14155238886
